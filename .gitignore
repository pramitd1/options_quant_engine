# Keep only the root repository README tracked
!/README.md

# Second-pass hardening (whitelist style): in mixed folders, only keep code-centric types trackable
# research/: allow source/config/shell/template marker files only
research/**
!research/
!research/**/
!research/**/*.py
!research/**/*.json
!research/**/*.sh
!research/**/*.template
!research/**/.gitkeep

# scripts/: allow executable and source artifacts only
scripts/**
!scripts/
!scripts/**/
!scripts/**/*.py
!scripts/**/*.sh
!scripts/**/*.template
!scripts/**/.gitkeep

# config/: allow policy/config source only
config/**
!config/
!config/**/
!config/**/*.py
!config/**/*.json
!config/**/*.template
!config/**/.gitkeep

# Test output directories (generated by pytest)
test_*Reports*/
test_*Tests_*/
test_*reports*/
test_*tests_*/

