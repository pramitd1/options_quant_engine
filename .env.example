ZERODHA_API_KEY=YOUR_ZERODHA_API_KEY
ZERODHA_API_SECRET=YOUR_ZERODHA_API_SECRET
ZERODHA_ACCESS_TOKEN=YOUR_ZERODHA_ACCESS_TOKEN

ICICI_BREEZE_API_KEY=YOUR_ICICI_BREEZE_API_KEY
ICICI_BREEZE_SECRET_KEY=YOUR_ICICI_BREEZE_SECRET_KEY
ICICI_BREEZE_SESSION_TOKEN=YOUR_ICICI_BREEZE_SESSION_TOKEN

# Optional manual fallback expiry. Leave blank to let the loader generate upcoming expiries.
ICICI_DEFAULT_EXPIRY_DATE=

# Optional comma-separated overrides, e.g. 2026-03-19T06:00:00.000Z,2026-03-26T06:00:00.000Z
ICICI_NIFTY_EXPIRIES=
ICICI_BANKNIFTY_EXPIRIES=
ICICI_FINNIFTY_EXPIRIES=

# Optional provider debug logs for integration work.
NSE_DEBUG=false
ICICI_DEBUG=false

# Runtime environment safety label (DEV, PROD, PRODUCTION).
OQE_RUNTIME_ENV=DEV

# Optional scheduled macro-event filter.
MACRO_EVENT_FILTER_ENABLED=false
MACRO_EVENT_SCHEDULE_FILE=config/india_macro_schedule.json
MACRO_EVENT_PRE_EVENT_WARNING_MINUTES=180
MACRO_EVENT_PRE_EVENT_LOCKDOWN_MINUTES=30
MACRO_EVENT_EVENT_DURATION_MINUTES=10
MACRO_EVENT_POST_EVENT_COOLDOWN_MINUTES=30

# Optional headline ingestion foundation.
HEADLINE_INGESTION_ENABLED=true
HEADLINE_PROVIDER=RSS
HEADLINE_MOCK_FILE=config/mock_headlines.example.json
HEADLINE_RSS_URLS=https://www.livemint.com/rss/markets,https://www.livemint.com/rss/news,https://www.livemint.com/rss/companies,https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms,https://economictimes.indiatimes.com/markets/stocks/rssfeeds/2146842.cms,https://economictimes.indiatimes.com/markets/options/rssfeeds/104728836.cms,https://economictimes.indiatimes.com/market-data/rssfeeds/110737294.cms,https://economictimes.indiatimes.com/news/economy/rssfeeds/1373380680.cms,https://www.sebi.gov.in/sebirss.xml
HEADLINE_RSS_TIMEOUT_SECONDS=8
HEADLINE_STALE_MINUTES=360
HEADLINE_MAX_RECORDS=50

# Optional global market risk feature sourcing.
GLOBAL_MARKET_DATA_ENABLED=true
GLOBAL_MARKET_LOOKBACK_DAYS=90
GLOBAL_MARKET_STALE_DAYS=5

# AI narrative for daily research reports (optional).
# Supports OpenAI or any OpenAI-compatible provider (e.g. Azure, local Ollama).
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1
REPORT_NARRATIVE_ENABLED=true

# Event-intelligence NLP overlay (optional LLM-assist extraction)
EVENT_INTELLIGENCE_ENABLED=true
EVENT_INTELLIGENCE_LLM_ENABLED=false
EVENT_INTELLIGENCE_LLM_PROVIDER=OPENAI
EVENT_INTELLIGENCE_LLM_MODEL=gpt-4o-mini
EVENT_INTELLIGENCE_LLM_TIMEOUT_SECONDS=8
EVENT_INTELLIGENCE_LLM_TEMPERATURE=0
EVENT_INTELLIGENCE_LLM_MIN_CONFIDENCE=0.62
