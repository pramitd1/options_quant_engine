ZERODHA_API_KEY=YOUR_ZERODHA_API_KEY
ZERODHA_API_SECRET=YOUR_ZERODHA_API_SECRET
ZERODHA_ACCESS_TOKEN=YOUR_ZERODHA_ACCESS_TOKEN

ICICI_BREEZE_API_KEY=YOUR_ICICI_BREEZE_API_KEY
ICICI_BREEZE_SECRET_KEY=YOUR_ICICI_BREEZE_SECRET_KEY
ICICI_BREEZE_SESSION_TOKEN=YOUR_ICICI_BREEZE_SESSION_TOKEN

# Optional manual fallback expiry. Leave blank to let the loader generate upcoming expiries.
ICICI_DEFAULT_EXPIRY_DATE=

# Optional comma-separated overrides, e.g. 2026-03-19T06:00:00.000Z,2026-03-26T06:00:00.000Z
ICICI_NIFTY_EXPIRIES=
ICICI_BANKNIFTY_EXPIRIES=
ICICI_FINNIFTY_EXPIRIES=

# Optional provider debug logs for integration work.
NSE_DEBUG=false
ICICI_DEBUG=false

# Optional scheduled macro-event filter.
MACRO_EVENT_FILTER_ENABLED=true
MACRO_EVENT_SCHEDULE_FILE=config/india_macro_schedule.json
MACRO_EVENT_PRE_EVENT_WARNING_MINUTES=180
MACRO_EVENT_PRE_EVENT_LOCKDOWN_MINUTES=30
MACRO_EVENT_EVENT_DURATION_MINUTES=10
MACRO_EVENT_POST_EVENT_COOLDOWN_MINUTES=30

# Optional headline ingestion foundation.
HEADLINE_INGESTION_ENABLED=true
HEADLINE_PROVIDER=MOCK
HEADLINE_MOCK_FILE=config/mock_headlines.example.json
HEADLINE_RSS_URLS=
HEADLINE_RSS_TIMEOUT_SECONDS=8
HEADLINE_STALE_MINUTES=45
HEADLINE_MAX_RECORDS=50
