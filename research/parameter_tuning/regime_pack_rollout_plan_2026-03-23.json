{
  "as_of": "2026-03-23",
  "objective": "Enable regime-conditional auto-switching safely with strict out-of-sample and regime-robustness gates.",
  "current_state": {
    "auto_switch_enabled": false,
    "live_pack": "baseline_v1",
    "baseline_pack": "baseline_v1",
    "candidate_pack": "candidate_v1",
    "available_packs": [
      {"name": "baseline_v1", "overrides": 0},
      {"name": "candidate_v1", "overrides": 0},
      {"name": "experimental_v1", "overrides": 5},
      {"name": "macro_overlay_v1", "overrides": 3},
      {"name": "overnight_focus_v1", "overrides": 6}
    ]
  },
  "training_priority": [
    {
      "pack": "macro_overlay_v1",
      "priority": 1,
      "target_regimes": {
        "gamma_regime_bucket": ["SHORT_GAMMA"],
        "vol_regime_bucket": ["HIGH_VOL"],
        "macro_regime_bucket": ["RISK_OFF", "EVENT_LOCKDOWN"]
      },
      "focus": [
        "macro/news adjustment penalties",
        "global risk overlay caution",
        "event-window conservatism"
      ]
    },
    {
      "pack": "experimental_v1",
      "priority": 2,
      "target_regimes": {
        "gamma_regime_bucket": ["LONG_GAMMA"],
        "vol_regime_bucket": ["NORMAL_VOL", "LOW_VOL"],
        "global_risk_bucket": ["GLOBAL_NEUTRAL", "RISK_ON"]
      },
      "focus": [
        "trade strength floor",
        "selection thresholds",
        "option efficiency filters"
      ]
    },
    {
      "pack": "overnight_focus_v1",
      "priority": 3,
      "target_regimes": {
        "overnight_bucket": ["OVERNIGHT_ALLOWED"],
        "event_risk_bucket": ["PRE_EVENT_WATCH", "POST_EVENT_COOLDOWN"],
        "vol_regime_bucket": ["HIGH_VOL"]
      },
      "focus": [
        "overnight hold constraints",
        "global risk caps",
        "overnight efficiency thresholds"
      ]
    }
  ],
  "validation_gates": {
    "aggregate": {
      "min_out_of_sample_score_delta_vs_baseline": 0.015,
      "min_out_of_sample_improvement": 0.005,
      "min_sample_count": 120,
      "min_frequency_ratio_candidate_over_baseline": 0.80
    },
    "robustness": {
      "min_robustness_score": 0.50,
      "max_split_score_dispersion": 0.07,
      "max_split_frequency_dispersion": 0.05,
      "max_insufficient_regime_count": 2
    },
    "regime_safety": {
      "min_target_regime_direction_hit_rate_delta": 0.02,
      "max_important_regime_collapse": -0.05
    },
    "risk": {
      "max_drawdown_proxy_ratio_candidate_over_baseline": 1.10
    },
    "governance": {
      "require_manual_approval": true,
      "minimum_shadow_days": 5
    }
  },
  "phases": [
    {
      "phase": 0,
      "name": "Preparation",
      "actions": [
        "keep auto-switch disabled",
        "run walk-forward + regime-aware validation for all 3 packs",
        "publish validation artifacts"
      ]
    },
    {
      "phase": 1,
      "name": "Shadow Routing",
      "actions": [
        "simulate SHORT_GAMMA+HIGH_VOL -> macro_overlay_v1",
        "simulate LONG_GAMMA+NORMAL_VOL -> experimental_v1",
        "keep overnight_focus_v1 shadow-only",
        "monitor for 5+ trading sessions"
      ]
    },
    {
      "phase": 2,
      "name": "Limited Live Enablement",
      "actions": [
        "enable only SHORT_GAMMA+HIGH_VOL -> macro_overlay_v1",
        "keep fallback baseline_v1 for all other routes",
        "monitor two-week rollback triggers"
      ]
    },
    {
      "phase": 3,
      "name": "Expanded Live Routing",
      "actions": [
        "add POSITIVE_GAMMA+NORMAL_VOL -> experimental_v1",
        "retain baseline fallback for unknown/low-sample regimes"
      ]
    },
    {
      "phase": 4,
      "name": "Overnight-Aware Extension",
      "actions": [
        "extend routing dimensions beyond gamma/vol",
        "only then consider live routing to overnight_focus_v1"
      ]
    }
  ],
  "initial_live_map_when_enabled": [
    {"gamma_regime": "NEGATIVE_GAMMA", "vol_regime": "HIGH_VOL", "pack": "macro_overlay_v1"},
    {"gamma_regime": "POSITIVE_GAMMA", "vol_regime": "NORMAL_VOL", "pack": "experimental_v1"}
  ],
  "fallback_pack": "baseline_v1"
}
